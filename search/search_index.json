hers/MarkdownLearn1/","title":"Markdown\u57fa\u672c\u8bed\u6cd5","text":"<p>Markdown \u5b98\u65b9\u6559\u7a0b</p>"},{"location":"others/MarkdownLearn1/#_1","title":"\u6807\u9898\u8bed\u6cd5","text":"<pre><code># \u4e00\u7ea7\u6807\u9898\n## \u4e8c\u7ea7\u6807\u9898\n### \u4e09\u7ea7\u6807\u9898\n\n\u4e00\u7ea7\u6807\u9898\n=====\n\u4e8c\u7ea7\u6807\u9898\n-------\n</code></pre>"},{"location":"others/MarkdownLearn1/#_2","title":"\u6bb5\u843d\u8bed\u6cd5","text":"<p>\u8230\u957f\uff0c\u6211\u771f\u7684\u8d85\u559c\u6b22\u4f60\u9001\u6211\u7684\u8fd9\u8eab\u8863\u670d\u5462\uff01</p> <p>\u5fb7\u8389\u838e\u662f\u4e0d\u662f\u53d8\u5f97\u8d8a\u6765\u8d8a\u53ef\u7231\u4e86\u5462\uff1f\uff01\u55b5~~~\uff01</p>"},{"location":"others/MarkdownLearn1/#_3","title":"\u6362\u884c\u8bed\u6cd5\uff08\u7ed3\u5c3e\u7a7a\u683c\uff09","text":"<p>\u8230\u957f\uff0c\u6211\u771f\u7684\u8d85\u559c\u6b22\u4f60 \u9001\u6211\u7684\u8fd9\u8eab\u8863\u670d\u5462\uff01</p>"},{"location":"others/MarkdownLearn1/#_4","title":"\u5f3a\u8c03\u8bed\u6cd5","text":""},{"location":"others/MarkdownLearn1/#_5","title":"\u7c97\u4f53","text":"<p>\u4f60\u5440\u6211\u5440\u5979\u5440\u3002</p>"},{"location":"others/MarkdownLearn1/#_6","title":"\u659c\u4f53","text":"<p>\u4f60\u5440\u6211\u5440\u5979\u5440\u3002</p>"},{"location":"others/MarkdownLearn1/#_7","title":"\u7c97\u4f53+\u659c\u4f53","text":"<p>\u4f60\u5440\u6211\u5440\u5979\u5440\u3002</p>"},{"location":"others/MarkdownLearn1/#_8","title":"\u5f15\u7528","text":"<p>hello world</p>"},{"location":"others/MarkdownLearn1/#_9","title":"\u5d4c\u5957\u5f15\u7528","text":"<p>hello world</p> <p>hello world</p>"},{"location":"others/MarkdownLearn1/#_10","title":"\u5e26\u6709\u5176\u4ed6\u5143\u7d20\u7684\u5757\u5f15\u7528","text":""},{"location":"others/MarkdownLearn1/#the-quarterly-results-look-great","title":"The quarterly results look great!","text":"<ul> <li>Revenue was off the chart.</li> <li>Profits were higher than ever.</li> </ul> <p>Everything is going according to plan.</p>"},{"location":"others/MarkdownLearn1/#_11","title":"\u5217\u8868\u8bed\u6cd5","text":""},{"location":"others/MarkdownLearn1/#_12","title":"\u6709\u5e8f\u5217\u8868","text":"<ol> <li>123</li> <li>32</li> <li>32<ol> <li>123</li> <li>33</li> <li>2</li> </ol> </li> <li>123</li> <li>22</li> </ol>"},{"location":"others/MarkdownLearn1/#_13","title":"\u65e0\u5e8f\u5217\u8868","text":"<ul> <li>123</li> <li>123</li> <li>321</li> </ul>"},{"location":"others/MarkdownLearn1/#_14","title":"\u5217\u8868\u4e2d\u5d4c\u5957\u5176\u4ed6\u5143\u7d20","text":""},{"location":"others/MarkdownLearn1/#_15","title":"\u6bb5\u843d","text":"<ul> <li>This is the first list item.</li> <li> <p>Here's the second list item.</p> <p>I need to add another paragraph below the second list item.</p> </li> <li> <p>And here's the third list item.</p> </li> </ul>"},{"location":"others/MarkdownLearn1/#_16","title":"\u5f15\u7528\u5757","text":"<ul> <li>This is the first list item.</li> <li> <p>Here's the second list item.</p> <p>A blockquote would look great below the second list item.</p> </li> <li> <p>And here's the third list item.</p> </li> </ul>"},{"location":"others/MarkdownLearn1/#_17","title":"\u4ee3\u7801\u5757","text":"<ol> <li>Open the file.</li> <li> <p>Find the following code block on line 21:</p> <pre><code>&lt;html&gt;\n  &lt;head&gt;\n    &lt;title&gt;Test&lt;/title&gt;\n  &lt;/head&gt;\n</code></pre> </li> <li> <p>Update the title to match the name of your website.</p> </li> </ol>"},{"location":"others/MarkdownLearn1/#_18","title":"\u56fe\u7247","text":"<ol> <li>Open the file containing the Linux mascot.</li> <li> <p>Marvel at its beauty.</p> <p></p> </li> <li> <p>Close the file.</p> </li> </ol>"},{"location":"others/MarkdownLearn1/#_19","title":"\u4ee3\u7801\u8bed\u6cd5","text":"<p>At the command prompt, type <code>nano</code>.</p>"},{"location":"others/MarkdownLearn1/#_20","title":"\u8f6c\u4e49\u53cd\u5f15\u53f7","text":"<p><code>Use `code` in your Markdown file.</code></